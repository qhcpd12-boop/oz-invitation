rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * No-auth 모델 (MVP):
     * - 공개 청첩장만 읽기 허용
     * - 클라이언트 쓰기는 buyerName+buyerPhone이 있는 발행/결제 상태 문서만 허용
     * - 주문/orders 는 서버(Admin SDK) 전용
     */
    function isPublishedDoc() {
      return resource.data.status in ['paid', 'published'];
    }

    function hasBuyerIdentity(data) {
      return data.buyerName is string
        && data.buyerName.size() > 0
        && data.buyerName.size() <= 80
        && data.buyerPhone is string
        && data.buyerPhone.matches('^[0-9]{10,11}$');
    }

    function hasWritableInvitationShape(data) {
      return data.templateId is string
        && data.wedding is map
        && data.gallery is list
        && data.status in ['awaiting_payment', 'paid', 'published'];
    }

    function hasExistingBuyerIdentity() {
      return resource.data.keys().hasAll(['buyerName', 'buyerPhone']);
    }

    function keepsSameBuyerIdentity() {
      return request.resource.data.buyerName == resource.data.buyerName
        && request.resource.data.buyerPhone == resource.data.buyerPhone;
    }

    match /invitations/{invitationId} {
      allow read: if isPublishedDoc();

      allow create: if hasBuyerIdentity(request.resource.data)
                    && hasWritableInvitationShape(request.resource.data);

      allow update: if hasBuyerIdentity(request.resource.data)
                    && hasWritableInvitationShape(request.resource.data)
                    && (
                      !hasExistingBuyerIdentity()
                      || keepsSameBuyerIdentity()
                    );

      allow delete: if false;
    }

    // 주문은 서버(Admin SDK) 전용
    match /orders/{orderId} {
      allow read, write: if false;
    }

    // 템플릿은 읽기 전용
    match /templates/{templateId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
